        <hasAffectedCountries>EU-wide</hasAffectedCountries>
        <hasAffectedDeviceCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">850</hasAffectedDeviceCount>
        <hasClosureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-01</hasClosureDate>
        <hasCorrectiveActionDescription>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</hasCorrectiveActionDescription>
        <hasEudamedFscaRef>EU-FSCA-2024-000001</hasEudamedFscaRef>
        <hasScope>All HeartMate 3 LVAD units implanted since 2020</hasScope>
        <rdfs:comment>Field safety corrective action related to incident INC-001</rdfs:comment>
        <rdfs:label>FSCA-001</rdfs:label>
    </owl:NamedIndividual>
    



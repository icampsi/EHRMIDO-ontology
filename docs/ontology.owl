    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#FSCA-001">
        <rdf:type rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#SafetyAlert"/>
        <relatedToIncident rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#INC-001"/>

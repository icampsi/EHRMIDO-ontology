<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#"
     xml:base="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:EHRMIDO="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2000/01/rdf-schema#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#sameAs"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#affectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#affectsDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:comment>Relates a risk to a specific device that may be affected by that risk</rdfs:comment>
        <rdfs:label>Affects Device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#affectsDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType"/>
        <rdfs:comment>Relates a risk to a specific device type that may be affected by that risk</rdfs:comment>
        <rdfs:label>Affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAssociatedRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAssociatedRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Relates an incident to a specific risk that caused it</rdfs:comment>
        <rdfs:label>Has associated Risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCategory -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCategory">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RiskCategory"/>
        <rdfs:comment>Relates a risk to a specific category of risks</rdfs:comment>
        <rdfs:label>Has category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCountry -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Country"/>
        <rdfs:comment>Relates a risk to a manufacturer to a specific country of procedence</rdfs:comment>
        <rdfs:label>Has Country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType"/>
        <rdfs:comment>Relates a device to a specific type</rdfs:comment>
        <rdfs:label>Has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasProbability -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasProbability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Probability"/>
        <rdfs:comment>Specifies the probability for a risk to actually happend</rdfs:comment>
        <rdfs:label>Has Probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RegulatoryFramework"/>
        <rdfs:comment>Relates the regulatory framework that legislates over a device</rdfs:comment>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RiskClass"/>
        <rdfs:comment>Relates a device to a specific risk class</rdfs:comment>
        <rdfs:label>Has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasSeverity -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasSeverity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Severity"/>
        <rdfs:label>Classifies the severity of a risk</rdfs:label>
        <rdfs:label>Has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#manufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#manufacturedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:label>Manufactured by</rdfs:label>
        <rdfs:label>Relates a device to its manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#relatedToIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#relatedToIncident">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:comment>relates an incident to a specific corrective action taken around it</rdfs:comment>
        <rdfs:label>Related to incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#reportedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:label>Reported by</rdfs:label>
        <rdfs:label>Specifies which manufacturer has reported a specific incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#reportedInCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Country"/>
        <rdfs:comment>relates an incident to the country its been reported at</rdfs:comment>
        <rdfs:label>Reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#correctiveActionTaken">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a corrective action has been taken in response to an incident</rdfs:comment>
        <rdfs:label>Corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasActionDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasActionDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Indicates whether a corrective action has been taken in response to an incident</rdfs:comment>
        <rdfs:label>Action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedCountries -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedCountries">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Countries or regions affected by a corrective action</rdfs:comment>
        <rdfs:label>Affected countries</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedDeviceCount -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedDeviceCount">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Number of devices affected by a corrective action</rdfs:comment>
        <rdfs:label>Affected device count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedPatientAge -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedPatientAge">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Age of the patient affected by an incident</rdfs:comment>
        <rdfs:label>Affected patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedPatientSex -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAffectedPatientSex">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Age of the patient affected by an incident</rdfs:comment>
        <rdfs:label>Affected patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAuthorizationNumber">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Regulatory authorization number assigned to a manufacturer</rdfs:comment>
        <rdfs:label>Has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasClosureDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasClosureDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>Closure date</rdfs:label>
        <rdfs:label>Date on which a corrective action was closed</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCompetentAuthority -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCompetentAuthority">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Authority responsible for the regulation</rdfs:comment>
        <rdfs:label>Competent authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasContactEmail">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Email address used to contact the manufacturer</rdfs:comment>
        <rdfs:label>Contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCorrectiveActionDescription -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCorrectiveActionDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of a corrective action</rdfs:comment>
        <rdfs:label>Corrective action description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasDetectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasDetectionDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date in which an incident was detected</rdfs:comment>
        <rdfs:label>Detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEudamedFscaRef">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>EUDAMED FSCA ref</rdfs:label>
        <rdfs:label>EUDEMED reference number for a FSCA</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEudamedIncidentRef">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>EUDAMED reference number for an incident</rdfs:comment>
        <rdfs:label>EUDAMED incident ref</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEudamedSrn -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEudamedSrn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>EUDAMED SRN</rdfs:comment>
        <rdfs:comment>Single Registration Number assigned to a manufacturer in EUDAMED</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEventDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasEventDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>Event date</rdfs:label>
        <rdfs:label>date in which the incident took place</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasImdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasImdrfCode">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Code assigned to a risk according to the IMDRF terminology</rdfs:comment>
        <rdfs:label>IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasIncidentDescription -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasIncidentDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of an incident</rdfs:comment>
        <rdfs:label>Incident description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasIntendedPurpose">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of the intended medical purpose or use of a device</rdfs:comment>
        <rdfs:label>Intended Purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasOutcome -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasOutcome">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Result or consequence of an incident involving a medical device</rdfs:comment>
        <rdfs:label>Outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasReportDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRiskDescription -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRiskDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of a risk</rdfs:comment>
        <rdfs:label>Risk description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasScope -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasScope">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Scope</rdfs:comment>
        <rdfs:comment>The scope of a corrective action</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasStatus -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasStatus">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Indicates whether a corrective action is closed</rdfs:comment>
        <rdfs:label>Status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasUdiDi -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasUdiDi">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique Device Identifier assigned to a medical device</rdfs:comment>
        <rdfs:label>UDI ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isActive">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a device is an active device</rdfs:comment>
        <rdfs:label>Is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isActiveDevice -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isActiveDevice">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a device Type represents an active device</rdfs:comment>
        <rdfs:label>Is active device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isImplantable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates wether a device is implantable</rdfs:comment>
        <rdfs:label>Is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isImplantableDevice -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isImplantableDevice">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>indicates wether a device type represents an implantable device</rdfs:comment>
        <rdfs:label>is implantable device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isIvd -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isIvd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a device is an in vitro diagnostic medical device</rdfs:comment>
        <rdfs:label>is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isReusable">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a device is reusable</rdfs:comment>
        <rdfs:label>Is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isReusableDevice -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#isReusableDevice">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates wether a device type represents a reusable device</rdfs:comment>
        <rdfs:label>Is reusable device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:comment>Medical device that depends on a power source</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#ContaminationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk involving external contaminant agents</rdfs:comment>
        <rdfs:label>Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#relatedToIncident"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Class representing a corrective action taken after an incident</rdfs:comment>
        <rdfs:label>Corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Country -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Country">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity"/>
        <rdfs:comment>Class representing a territory related with the manufacturer of a device or an incident</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk related to the software security of the device</rdfs:comment>
        <rdfs:label>Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasDeviceType"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRegulatoryFramework"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RegulatoryFramework"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasRiskClass"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RiskClass"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#manufacturedBy"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Medical device registered in the catalogue</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity"/>
        <rdfs:comment>Class encapsulating the type of a device</rdfs:comment>
        <rdfs:label>Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk related to incorrect or incomplete diagnostic results produced by a medical device</rdfs:comment>
        <rdfs:label>Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#IVDRRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#IVDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MDRRiskClass"/>
        <rdfs:comment>Risk class for medical devices under the IVDR regulatory framework</rdfs:comment>
        <rdfs:label>IVDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Device"/>
        <rdfs:comment>Medical device that should be implanted in the human body</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#InSituCorrection -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#CorrectiveAction"/>
        <rdfs:comment>Class representing a corrective action made in situ</rdfs:comment>
        <rdfs:label>In situ correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasAssociatedRisk"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#reportedBy"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Class that represents an incident with a medical device</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#IncidentWithCorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#IncidentWithCorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>
        <rdfs:comment>Class that represents an incident that needs acorrectove action</rdfs:comment>
        <rdfs:label>Incident with corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#InfectionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk of infection related to a medical device</rdfs:comment>
        <rdfs:label>Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#InjuryRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk that the device could cause an injury</rdfs:comment>
        <rdfs:label>Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MDRRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#RiskClass"/>
        <rdfs:comment>Risk class for medical devices under the MDR regulatory framework</rdfs:comment>
        <rdfs:label>MDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MalfunctionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk of device malfunction</rdfs:comment>
        <rdfs:label>Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#hasCountry"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Country"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Manufacturer of a catalogued medical device</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MaterialRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Risk"/>
        <rdfs:comment>Risk related to the materials, substances or components used in a medical device.</rdfs:comment>
        <rdfs:label>Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#MedicalEntity">
        <rdfs:comment>General class representing any entity related to medical devices, risks, incidents, manufacturers or corrective actions</rdfs:comment>
        <rdfs:label>Medical entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#NearMissIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/brams/ontologies/2026/3/EHRMIDO#Incident"/>

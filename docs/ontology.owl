        <hasAffectedPatientAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">58</hasAffectedPatientAge>
        <hasAffectedPatientSex>Male</hasAffectedPatientSex>
        <hasDetectionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-10</hasDetectionDate>
